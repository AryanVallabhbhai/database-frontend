# Copy this file to `.env` and fill in real values. Never commit real secrets.

# Frontend (Vite)
VITE_DB_ENDPOINT=http://localhost:3001/db?test=true
VITE_DB_TOKEN=replace-with-strong-token

# Backend / Proxy
SERVER_PORT=3001
CORS_ORIGIN=http://localhost:5173
API_TOKEN=replace-with-strong-token

# Aiven MySQL (replace with values from Aiven console)
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=12345
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=restaurant_schema
DB_NAME_TEST=demo
DEFAULT_USE_TEST_DB=true
DB_SSL_CA_PATH=/path/to/aiven-ca.pem

# Local MySQL (optional)
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=3306
LOCAL_DB_USER=root
LOCAL_DB_PASS=example
LOCAL_DB_NAME=restaurant_schema
